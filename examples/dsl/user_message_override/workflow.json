{
  "version": "1.0",
  "name": "user_message_override",
  "description": "Demonstrates builtin.llmagent.config.user_message overriding the per-node user message with upstream outputs.",
  "nodes": [
    {
      "id": "start",
      "label": "Start",
      "node_type": "builtin.start",
      "config": {}
    },
    {
      "id": "build_message",
      "label": "Build per-node user message",
      "node_type": "builtin.transform",
      "config": {
        "expr": {
          "expression": "{\n  \"original_user_input\": state.user_input,\n  \"overridden_user_message\": \"OVERRIDDEN USER MESSAGE: [\" + state.user_input + \"]\"\n}",
          "format": "cel"
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "original_user_input": {
              "type": "string",
              "description": "Original workflow input (state.user_input)"
            },
            "overridden_user_message": {
              "type": "string",
              "description": "Computed per-node user message to be sent to the model"
            }
          },
          "required": [
            "original_user_input",
            "overridden_user_message"
          ],
          "additionalProperties": false
        }
      }
    },
    {
      "id": "echo_agent",
      "label": "Echo agent",
      "node_type": "builtin.llmagent",
      "config": {
        "model_spec": {
          "provider": "openai",
          "model_name": "env:OPENAI_MODEL",
          "base_url": "env:OPENAI_BASE_URL",
          "api_key": "env:OPENAI_API_KEY"
        },
        "instruction": "You are a test assistant.\n\nDecide whether the user message starts with the literal prefix \"OVERRIDDEN USER MESSAGE:\".\n\n- If YES, output exactly: OVERRIDE_MODE\n- If NO, output exactly: DEFAULT_MODE\n\nDo not output anything else.",
        "user_message": "{{input.output_parsed.overridden_user_message}}",
        "history": "invocation",
        "output_format": {
          "type": "text"
        },
        "temperature": 0
      }
    },
    {
      "id": "end",
      "label": "End",
      "node_type": "builtin.end",
      "config": {
        "expr": {
          "expression": "{\n  \"original_user_input\": nodes.build_message.output_parsed.original_user_input,\n  \"overridden_user_message\": nodes.build_message.output_parsed.overridden_user_message,\n  \"agent_output\": nodes.echo_agent.output_text\n}",
          "format": "cel"
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "original_user_input": {
              "type": "string",
              "description": "Original workflow input (state.user_input)"
            },
            "overridden_user_message": {
              "type": "string",
              "description": "Per-node user message passed to the model"
            },
            "agent_output": {
              "type": "string",
              "description": "What the LLM agent produced"
            }
          },
          "required": [
            "original_user_input",
            "overridden_user_message",
            "agent_output"
          ],
          "additionalProperties": false
        }
      }
    }
  ],
  "edges": [
    {
      "id": "edge_start_build_message",
      "source": "start",
      "target": "build_message"
    },
    {
      "id": "edge_build_message_echo_agent",
      "source": "build_message",
      "target": "echo_agent"
    },
    {
      "id": "edge_echo_agent_end",
      "source": "echo_agent",
      "target": "end"
    }
  ],
  "conditional_edges": [],
  "start_node_id": "start"
}
