{
  "version": "1.0",
  "name": "mcp_node_weather",
  "description": "Demonstrates Start -> Agent -> Transform -> MCP(add) -> Transform -> End chain.",
  "nodes": [
    {
      "id": "start",
      "label": "Start",
      "node_type": "builtin.start",
      "config": {}
    },
    {
      "id": "planner_agent",
      "label": "Planner Agent",
      "node_type": "builtin.llmagent",
      "config": {
        "model_spec": {
          "provider": "openai",
          "model_name": "env:OPENAI_MODEL",
          "base_url": "env:OPENAI_BASE_URL",
          "api_key": "env:OPENAI_API_KEY"
        },
        "instruction": "You are a helper that extracts two integers for addition. Read the user input and output the two numbers to add.",
        "output_format": {
          "type": "json",
          "schema": {
            "type": "object",
            "properties": {
              "a": {
                "type": "integer",
                "description": "First integer to add"
              },
              "b": {
                "type": "integer",
                "description": "Second integer to add"
              }
            },
            "required": ["a", "b"],
            "additionalProperties": false
          }
        },
        "temperature": 0.2,
        "max_tokens": 128
      }
    },
    {
      "id": "prepare_request",
      "label": "Prepare MCP request",
      "node_type": "builtin.transform",
      "config": {
        "expr": {
          "expression": "{ \"a\": input.output_parsed.a, \"b\": input.output_parsed.b }",
          "format": "cel"
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "a": {
              "type": "integer",
              "description": "First integer argument for add"
            },
            "b": {
              "type": "integer",
              "description": "Second integer argument for add"
            }
          },
          "required": ["a", "b"],
          "additionalProperties": false
        }
      }
    },
    {
      "id": "mcp_weather",
      "label": "Call MCP add",
      "node_type": "builtin.mcp",
      "config": {
        "mcp": {
          "name": "calculator_sse",
          "transport": "sse",
          "server_url": "http://03.mcp-gateway.woa.com/245oyJGZ7scEkoA0",
          "timeout": 30
        },
        "function": "add"
      }
    },
    {
      "id": "format_summary",
      "label": "Format add summary",
      "node_type": "builtin.transform",
      "config": {
        "expr": {
          "expression": "{ \"summary\": \"Addition result is \" + string(nodes.mcp_weather.output_parsed), \"raw\": nodes.mcp_weather.output_parsed }",
          "format": "cel"
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "summary": {
              "type": "string",
              "description": "Human-readable addition summary"
            },
            "raw": {
              "description": "Raw MCP add result"
            }
          },
          "required": ["summary"],
          "additionalProperties": false
        }
      }
    },
    {
      "id": "end",
      "label": "End",
      "node_type": "builtin.end",
      "config": {
        "expr": {
          "expression": "{ \"message\": nodes.format_summary.output_parsed.summary, \"result\": nodes.format_summary.output_parsed.raw }",
          "format": "cel"
        },
        "output_schema": {
          "type": "object",
          "properties": {
            "message": {
              "type": "string",
              "description": "Addition summary message"
            },
            "result": {
              "description": "Raw structured addition result"
            }
          },
          "required": ["message"],
          "additionalProperties": false
        }
      }
    }
  ],
  "edges": [
    {
      "id": "edge_start_agent",
      "source": "start",
      "target": "planner_agent"
    },
    {
      "id": "edge_agent_prepare",
      "source": "planner_agent",
      "target": "prepare_request"
    },
    {
      "id": "edge_prepare_mcp",
      "source": "prepare_request",
      "target": "mcp_weather"
    },
    {
      "id": "edge_mcp_format",
      "source": "mcp_weather",
      "target": "format_summary"
    },
    {
      "id": "edge_format_end",
      "source": "format_summary",
      "target": "end"
    }
  ],
  "conditional_edges": [],
  "start_node_id": "start"
}
