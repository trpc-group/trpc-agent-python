# LLM Model Configuration
# Set these environment variables to use your preferred LLM provider

# API key for your LLM provider
TRPC_AGENT_API_KEY=your_api_key_here

# Base URL for the LLM API (e.g., https://api.openai.com/v1 for OpenAI)
TRPC_AGENT_BASE_URL=https://api.deepseek.com

# Model name to use (e.g., deepseek-chat, gpt-4, etc.)
TRPC_AGENT_MODEL_NAME=deepseek-chat
