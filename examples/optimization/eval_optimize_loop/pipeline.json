{
  "optimizer_config": "optimizer.json",
  "regression_metrics_config": "regression.metrics.json",
  "gate_config": "gate.json",
  "train_dataset": "data/train.evalset.json",
  "validation_dataset": "data/val.evalset.json",
  "target_prompts": {
    "system": "agent/prompts/system.md"
  },
