{
  "config_version": 1,
  "execution": {
    "mode": "fake",
    "fake_candidate_scenario": "improve",
    "use_fake_judge": false
  },
  "inputs": {
    "train_evalset": "data/train.evalset.json",
    "validation_evalset": "data/val.evalset.json",
    "optimizer_config": "optimizer.json"
  },
  "prompts": [
    {
      "name": "system_prompt",
      "path": "prompts/system.md"
    }
  ],
  "run": {
    "runs_dir": "runs",
    "seed": 42
  },
  "case_labels": {
    "hard_case_ids": ["val_knowledge_recall"],
    "critical_case_ids": ["val_refund_route"]
  },
  "gate": {
    "min_validation_score_delta": 0.05,
    "reject_on_validation_pass_rate_drop": true,
    "reject_new_hard_fail": true,
    "reject_critical_regression": true,
    "severe_case_score_drop": 0.2,
    "required_metrics": ["final_response_avg_score"]
  },
  "budget": {
    "max_duration_seconds": 180,
    "on_unavailable": "warning"
  },
  "reporting": {
    "write_json": true,
    "write_markdown": true,
    "include_case_evidence": true
  },
  "artifacts": {
    "copy_input_files": true,
    "retain_optimizer_native_artifacts": true,
    "audit_all_candidates": false
  },
  "writeback": {
    "enabled": false,
    "require_source_hash_match": true
  }
}
