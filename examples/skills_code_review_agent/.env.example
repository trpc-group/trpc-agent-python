# All variables are OPTIONAL — the example runs fully offline by default
# (--dry-run / --model-mode fake needs no key at all).
#
# NOTE: this file is NOT loaded automatically (no dotenv dependency). Export
# the variables into your shell yourself, e.g.:
#   set -a; source .env; set +a

# Only used with --model-mode real (LLM summary stage):
TRPC_AGENT_API_KEY=your_api_key
TRPC_AGENT_BASE_URL=https://api.openai.com/v1
TRPC_AGENT_MODEL_NAME=gpt-4o-mini

# Only used with --sandbox cube (Cube/E2B workspace runtime):
E2B_API_KEY=your_e2b_key
