+++ b/app/billing.py
@@ -0,0 +1,17 @@
+import sqlite3
+
+
+def apply_charges(db_path: str, charges) -> int:
+    """Apply a batch of charges inside one transaction."""
+    conn = sqlite3.connect(db_path)
+    cur = conn.cursor()
+    cur.execute("BEGIN")
+    applied = 0
+    for account_id, amount in charges:
+        cur.execute(
+            "UPDATE accounts SET balance = balance - ? WHERE id = ?",
+            (amount, account_id),
+        )
+        applied += 1
+    return applied
+
