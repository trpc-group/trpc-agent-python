+def execute_user_script(script_path: str, language: str) -> str:
+    """执行用户脚本"""
+    # 跨语言安全：根据语言类型执行任意脚本
+    interpreters = {
+        "js": "node",
+        "py": "python",
+        "rb": "ruby",
+        "sh": "bash"
+    }
+    interpreter = interpreters.get(language, "python")
