+import asyncio
+import time
+
+
+async def process_items(items: list) -> list:
+    results = []
+    for item in items:
+        time.sleep(0.1)  # Blocks event loop
+        results.append(item * 2)
+    return results
+
+
+def read_file():
+    f = open("data.txt")
+    data = f.read()
+    return data  # f never closed
