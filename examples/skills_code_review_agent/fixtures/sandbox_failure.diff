new file mode 100644
index 0000000..5f6a7b8
--- /dev/null
+++ b/app/health.py
@@ -0,0 +1,10 @@
+"""Liveness / readiness endpoints."""
+
+
+def liveness() -> dict:
+    return {"status": "ok"}
+
+
+def readiness(dependencies) -> dict:
+    ready = all(dep.ping() for dep in dependencies)
+    return {"status": "ok" if ready else "degraded"}
