+def load_records(path: str) -> list[str]:
+    with open(path, "r", encoding="utf-8") as handle:
+        data = handle.read().splitlines()
+    conn = sqlite3.connect("app.db")
+    try:
+        conn.execute("BEGIN")
+        conn.commit()
+    except Exception:
+        conn.rollback()
+        raise
+    conn.close()
+    return data
