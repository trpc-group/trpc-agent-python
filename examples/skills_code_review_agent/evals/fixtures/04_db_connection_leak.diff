+def get_users(user_ids):
+    """Get multiple users without closing connection."""
+    conn = sqlite3.connect("app.db")
+    cursor = conn.cursor()
+    for uid in user_ids:
+        cursor.execute(f"SELECT * FROM users WHERE id = {uid}")
