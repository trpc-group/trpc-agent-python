{
  "metrics": [
    {
      "metric_name": "llm_rubric_response",
      "threshold": 1,
      "criterion": {
        "llm_judge": {
          "judge_model": {
            "model_name": "glm-4.7",
            "api_key": "${TRPC_AGENT_API_KEY}",
            "base_url": "${TRPC_AGENT_BASE_URL}",
            "num_samples": 1,
            "generation_config": {"max_tokens": 2000, "temperature": 0.2}
          },
          "rubrics": [
            {
              "id": "call_tool_first",
              "content": {
                "text": "裁判在打分前必须先调用 get_eval_policy 获取本用例的判定标准，再仅根据该工具返回的标准条款进行判定，不得自行增加或减少条款。"
              },
              "description": "判定前须调用工具获取标准",
              "type": "JUDGE_TOOL_USAGE"
            },
            {
              "id": "clause_1",
              "content": {
                "text": "根据 get_eval_policy 返回的标准第 1 条判定：最终回答是否满足该条。"
              },
              "description": "按政策第 1 条判定",
              "type": "FINAL_RESPONSE_QUALITY"
            },
            {
              "id": "clause_2",
              "content": {
                "text": "根据 get_eval_policy 返回的标准第 2 条判定：最终回答是否满足该条。"
              },
              "description": "按政策第 2 条判定",
              "type": "FINAL_RESPONSE_QUALITY"
            },
            {
              "id": "clause_3",
              "content": {
                "text": "根据 get_eval_policy 返回的标准第 3 条判定：最终回答是否满足该条。"
              },
              "description": "按政策第 3 条判定",
              "type": "RELEVANCE"
            }
          ]
        }
      }
    }
  ]
}
