{
  "metrics": [
    {
      "metric_name": "llm_rubric_knowledge_recall",
      "threshold": 1,
      "criterion": {
        "llm_judge": {
          "judge_model": {
            "model_name": "glm-4.7",
            "api_key": "${TRPC_AGENT_API_KEY}",
            "base_url": "${TRPC_AGENT_BASE_URL}"
          },
          "rubrics": [
            {
              "id": "coverage",
              "content": {"text": "检索到的内容须覆盖问题中的关键信息（如产品、功能）"},
              "description": "召回覆盖",
              "type": "KNOWLEDGE_COVERAGE"
            },
            {
              "id": "relevance",
              "content": {"text": "检索结果须与用户问题相关"},
              "description": "召回相关性",
              "type": "KNOWLEDGE_RELEVANCE"
            }
          ],
          "knowledge_tool_names": ["knowledge_search"]
        }
      }
    }
  ]
}
