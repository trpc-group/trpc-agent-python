# Base images 基础镜像
FROM mirrors.tencent.com/tlinux/tlinux3.2:v20200830

ENV no_proxy="mirrors.tencent.com"
ENV LD_LIBRARY_PATH /usr/local/lib:$LD_LIBRARY_PATH


RUN yum -y install cmake gcc git zlib libffi git-lfs \
    && yum -y install openssl-devel bzip2-devel libffi-devel zlib-devel xz-devel snappy-devel mariadb-devel sqlite-devel libarchive \
    && yum -y install readline-devel epel-release python3-tkinter \
    && yum clean all \
   	&& wget https://www.python.org/ftp/python/3.10.2/Python-3.10.2.tgz   \
   	&& tar xzf Python-3.10.2.tgz \
  	&& cd Python-3.10.2 \
   	&& ./configure --prefix=/usr --with-platlibdir=lib64 --enable-optimizations -enable-shared --enable-ipv6 --enable-loadable-sqlite-extensions \
    && make -j8 \
    && make install \
    && cd - \
   	&& rm -rf Python-3.10.2 \
   	&& rm Python-3.10.2.tgz \
    && sudo rm -rf /usr/bin/node \
    && sudo rm -rf /usr/bin/npm \
    && wget https://nodejs.org/dist/v22.17.0/node-v22.17.0-linux-x64.tar.xz \
    && tar -xvf node-v22.17.0-linux-x64.tar.xz -C /opt/ \
    && sudo ln -sf /opt/node-v22.17.0-linux-x64/bin/node /usr/bin/node \
    && sudo ln -sf /opt/node-v22.17.0-linux-x64/bin/npm /usr/bin/npm \
    && chmod +x /usr/bin/node /usr/bin/npm \
    && rm -rf node-v22.17.0-linux-x64 node-v22.17.0-linux-x64.tar.xz \
    && git clone https://github.com/google/adk-web.git \
    && cd adk-web \
    && npm install \
    && pip3 install --upgrade pip \
    && pip3 install --upgrade setuptools \
    && pip3 install --no-cache-dir wheel \
    && pip3 install --no-cache-dir requests \
    && pip3 install --no-cache-dir requests-toolbelt \
    && yum clean all \
    && cd ~


